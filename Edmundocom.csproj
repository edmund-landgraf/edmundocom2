<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>edmundocom2-contact-email</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="Edmundocom.Blog\Edmundocom.Blog.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Edmundocom.Blog\**\*.cs" />
    <Content Remove="Edmundocom.Blog\**\*" />
    <None Remove="Edmundocom.Blog\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Content\Blog\**\*.md" CopyToPublishDirectory="PreserveNewest" />
    <Content Update="Content\Photos\**\*.json" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
