@page
@{
    ViewData["Title"] = "Activities";
}

<section class="page-section">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Activities</p>
            <h1>Things I am doing and keeping track of.</h1>
            <p>
                A personal dashboard for hobbies, projects, routines, learning, family plans, and the stuff that does not
                need to be a formal blog post.
            </p>
        </div>
        <div class="activity-grid">
            <article>
                <h2>Current</h2>
                <p>What is active right now: site work, experiments, repairs, research, and recurring commitments.</p>
            </article>
            <article>
                <h2>Learning</h2>
                <p>Notes from books, tools, classes, technical rabbit holes, and ideas worth circling back to.</p>
            </article>
            <article>
                <h2>Home base</h2>
                <p>Useful personal references, reminders, lists, and little systems that make daily life easier.</p>
            </article>
            <article>
                <h2>Business adjacent</h2>
                <p>Anything client-facing can point outward to <a href="https://unwhelm.net">unwhelm.net</a>.</p>
            </article>
        </div>
    </div>
</section>
