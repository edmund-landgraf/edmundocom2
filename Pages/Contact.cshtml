@page
@model ContactModel
@{
    ViewData["Title"] = "Contact";
}

<section class="page-section">
    <div class="container contact-grid">
        <div>
            <p class="eyebrow">Contact</p>
            <h1>Say hello, send a note, or follow the business trail.</h1>
            <p>
                Send a note here and it will go straight to Edmund by email. For client-facing work,
                the business side still lives at <a href="https://unwhelm.net">unwhelm.net</a>.
            </p>
        </div>
        <div class="contact-panel contact-form-panel">
            <h2>Send a message</h2>

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="form-alert success" role="status">@Model.SuccessMessage</div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="form-alert error" role="alert" asp-validation-summary="ModelOnly"></div>
            }

            <form method="post" class="contact-form">
                <div class="form-row">
                    <label asp-for="Input.Name"></label>
                    <input asp-for="Input.Name" autocomplete="name" />
                    <span asp-validation-for="Input.Name"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" autocomplete="email" />
                    <span asp-validation-for="Input.Email"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Subject"></label>
                    <input asp-for="Input.Subject" />
                    <span asp-validation-for="Input.Subject"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Message"></label>
                    <textarea asp-for="Input.Message" rows="6"></textarea>
                    <span asp-validation-for="Input.Message"></span>
                </div>

                <div class="form-row honeypot" aria-hidden="true">
                    <label asp-for="Input.Website"></label>
                    <input asp-for="Input.Website" tabindex="-1" autocomplete="off" />
                </div>

                <div class="captcha-box">
                    <div>
                        <label asp-for="Input.CaptchaAnswer">Captcha: @Model.CaptchaQuestion</label>
                        <p>Answer the quick math check before sending.</p>
                    </div>
                    <input asp-for="Input.CaptchaAnswer" inputmode="numeric" autocomplete="off" />
                </div>
                <span asp-validation-for="Input.CaptchaAnswer"></span>

                <button class="button-primary" type="submit">Send message</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
