@page
@{
    ViewData["Title"] = "Contact";
}

<section class="page-section">
    <div class="container contact-grid">
        <div>
            <p class="eyebrow">Contact</p>
            <h1>Say hello, send a note, or follow the business trail.</h1>
            <p>
                This page can become the future home for a contact form, email link, scheduling link, or a short intake flow.
            </p>
        </div>
        <div class="contact-panel">
            <h2>Useful links</h2>
            <ul>
                <li>Personal updates live here on edmundo.com.</li>
                <li>Business work can point to <a href="https://unwhelm.net">unwhelm.net</a>.</li>
                <li>A real form endpoint can be added when the deployment target is set.</li>
            </ul>
        </div>
    </div>
</section>
