@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="container hero-grid">
        <div>
            <p class="eyebrow">edmundo.com</p>
            <h1>A personal place for what I am doing, where I have been, and what I want to keep handy.</h1>
            <p class="hero-copy">
                Notes, activities, trips, photos, videos, projects, and a public link shelf. Business work can still point
                cleanly to <a href="https://unwhelm.net">unwhelm.net</a>.
            </p>
            <div class="hero-actions">
                <a class="button-primary" asp-page="/Activities">Activities</a>
                <a class="button-secondary" asp-page="/Trips">Trips</a>
                <a class="button-secondary" asp-page="/Links">Links</a>
            </div>
        </div>
        <div class="status-panel personal-panel" aria-label="Personal site sections">
            <span class="status-dot"></span>
            <h2>Personal shelves</h2>
            <dl>
                <div>
                    <dt>Doing</dt>
                    <dd>Activities</dd>
                </div>
                <div>
                    <dt>Going</dt>
                    <dd>Trips</dd>
                </div>
                <div>
                    <dt>Saving</dt>
                    <dd>Links</dd>
                </div>
            </dl>
        </div>
    </div>
</section>

<section class="content-band">
    <div class="container feature-grid">
        <article>
            <h2>Activities</h2>
            <p>Current interests, recurring things, projects-in-motion, and the ordinary rhythms worth remembering.</p>
            <a asp-page="/Activities">Open activities</a>
        </article>
        <article>
            <h2>Trips</h2>
            <p>Places visited, plans in progress, travel notes, photos, routes, and little discoveries along the way.</p>
            <a asp-page="/Trips">Open trips</a>
        </article>
        <article>
            <h2>Public links</h2>
            <p>A tidy launch point for resources, albums, shared docs, and destinations that may ask for authentication.</p>
            <a asp-page="/Links">Open links</a>
        </article>
    </div>
</section>

<section class="split-section">
    <div class="container split-grid">
        <div class="section-intro">
            <p class="eyebrow">Personal, not corporate</p>
            <h2>Quiet pages for real-life categories.</h2>
            <p>
                The site can grow around activities, travel, media, writing, and personal references without turning into
                a heavy portfolio page.
            </p>
        </div>
        <div class="note-stack">
            <div>
                <h3>Here</h3>
                <p>Personal notes, activities, trips, photos, videos, projects, and public link shortcuts.</p>
            </div>
            <div>
                <h3>unwhelm.net</h3>
                <p>Business services, client-facing language, and the cleaner consulting lane.</p>
            </div>
        </div>
    </div>
</section>
