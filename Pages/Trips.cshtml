@page
@{
    ViewData["Title"] = "Trips";
}

<section class="page-section">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Trips</p>
            <h1>Places, plans, routes, and memories.</h1>
            <p>
                A place for travel notes, photo sets, future itineraries, favorite stops, and links to albums or maps.
            </p>
        </div>
        <div class="trip-list">
            <article>
                <span>Planned</span>
                <div>
                    <h2>Future trips</h2>
                    <p>Ideas, dates, wish lists, route sketches, reservations, and shared planning links.</p>
                </div>
            </article>
            <article>
                <span>Past</span>
                <div>
                    <h2>Trip archive</h2>
                    <p>Notes, photos, videos, lessons learned, and places that are worth visiting again.</p>
                </div>
            </article>
            <article>
                <span>Shared</span>
                <div>
                    <h2>Albums and maps</h2>
                    <p>Public links can live here, while private albums can redirect to the service that handles login.</p>
                </div>
            </article>
        </div>
    </div>
</section>
