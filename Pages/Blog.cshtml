@page
@{
    ViewData["Title"] = "Blog";
}

<section class="page-section">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Blog</p>
            <h1>Notes, updates, and things worth remembering.</h1>
            <p>
                A simple place for posts that can be practical, personal, technical, or unfinished in the useful way.
            </p>
        </div>
        <div class="post-grid">
            <article>
                <p class="post-date">May 2026</p>
                <h2>Rebuilding edmundo.com</h2>
                <p>Starting fresh with Razor Pages, HTTP first, and enough structure to grow without turning stiff.</p>
            </article>
            <article>
                <p class="post-date">Draft</p>
                <h2>What belongs on a personal site?</h2>
                <p>Photos, projects, notes, links, half-formed ideas, and the parts of the work that feel human.</p>
            </article>
            <article>
                <p class="post-date">Draft</p>
                <h2>Business lives at unwhelm.net</h2>
                <p>A cleaner line between personal publishing and client-facing consulting.</p>
            </article>
        </div>
    </div>
</section>
