@page
@model PhotosVideosModel
@{
    ViewData["Title"] = "Photos & Videos";
}

<section class="page-section">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Photos &amp; Videos</p>
            <h1>Photos, clips, and visual notes from the road.</h1>
            <p>
                A public shelf for trips, activities, project snapshots, and the bits worth sharing without needing a login.
            </p>
        </div>

        @if (Model.Media.Count == 0)
        {
            <div class="empty-state">
                <p>Nothing public has been shared here yet.</p>
            </div>
        }
        else
        {
            <div class="photo-gallery">
                @foreach (var item in Model.Media)
                {
                    <article class="photo-card">
                        @if (!string.IsNullOrWhiteSpace(item.MediaUrl) && item.IsVideo)
                        {
                            <video controls preload="metadata">
                                <source src="@item.MediaUrl" type="@item.MimeType" />
                            </video>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                        {
                            <a href="@(string.IsNullOrWhiteSpace(item.ProductUrl) ? item.MediaUrl : item.ProductUrl)" target="_blank" rel="noopener">
                                <img src="@item.ThumbnailUrl" alt="@item.DisplayTitle" loading="lazy" />
                            </a>
                        }
                        else
                        {
                            <div class="media-placeholder photo"></div>
                        }
                        <div>
                            <h2>@item.DisplayTitle</h2>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p>@item.Description</p>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
