@page
@{
    ViewData["Title"] = "Photos & Videos";
}

<section class="page-section">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Photos &amp; Videos</p>
            <h1>Media shelves for photos, clips, and visual notes.</h1>
            <p>
                This can become the organized home for galleries, short videos, project snapshots, and embedded media.
            </p>
        </div>
        <div class="media-grid">
            <article>
                <div class="media-placeholder photo"></div>
                <h2>Photo albums</h2>
                <p>Grouped by trip, project, family event, or whatever deserves its own little corner.</p>
            </article>
            <article>
                <div class="media-placeholder video"></div>
                <h2>Video clips</h2>
                <p>Embedded videos, local clips, walkthroughs, demos, or short personal updates.</p>
            </article>
            <article>
                <div class="media-placeholder archive"></div>
                <h2>Archive</h2>
                <p>Older images and media can be kept browsable without making the home page crowded.</p>
            </article>
        </div>
    </div>
</section>
