@page
@{
    ViewData["Title"] = "About";
}

<section class="page-section">
    <div class="container narrow">
        <p class="eyebrow">About</p>
        <h1>edmundo.com is the personal home base.</h1>
        <p>
            This site is for notes, photos, videos, project history, experiments, and the quieter parts of work
            that do not belong on a polished business landing page.
        </p>
        <p>
            The business side can point to <a href="https://unwhelm.net">unwhelm.net</a>, while edmundo.com stays more personal,
            flexible, and honest about what is being learned and made.
        </p>
        <div class="info-grid">
            <div>
                <h2>What goes here</h2>
                <p>Blog posts, media, project notes, links, and personal updates.</p>
            </div>
            <div>
                <h2>What goes there</h2>
                <p>Client services, business positioning, and official consulting material at unwhelm.net.</p>
            </div>
        </div>
    </div>
</section>
