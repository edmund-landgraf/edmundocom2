@page "{slug?}"
@model EditModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@{
    ViewData["Title"] = Model.IsNew ? "New Blog Post" : "Edit Blog Post";
}

<section class="page-section">
    <div class="container">
        <p class="eyebrow">Admin</p>
        <h1>@(Model.IsNew ? "New blog post" : "Edit blog post")</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="form-alert error" role="alert" asp-validation-summary="ModelOnly"></div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="form-alert success" role="status">@Model.SuccessMessage</div>
        }

        <form method="post" class="admin-edit-form">
            <div class="form-row">
                <label asp-for="Input.Title"></label>
                <input asp-for="Input.Title" />
                <span asp-validation-for="Input.Title"></span>
            </div>
            <div class="form-row">
                <label asp-for="Input.Slug"></label>
                <input asp-for="Input.Slug" readonly="@(!Model.IsNew)" />
                <span asp-validation-for="Input.Slug"></span>
            </div>
            <div class="form-row">
                <label asp-for="Input.Summary"></label>
                <textarea asp-for="Input.Summary" rows="3"></textarea>
                <span asp-validation-for="Input.Summary"></span>
            </div>
            <div class="admin-form-grid">
                <div class="form-row">
                    <label asp-for="Input.PublishedOn"></label>
                    <input asp-for="Input.PublishedOn" type="date" />
                    <span asp-validation-for="Input.PublishedOn"></span>
                </div>
                <div class="form-row">
                    <label asp-for="Input.Tags"></label>
                    <input asp-for="Input.Tags" />
                    <span asp-validation-for="Input.Tags"></span>
                </div>
            </div>
            <div class="form-row">
                <label class="checkbox-row">
                    <input asp-for="Input.IsDraft" />
                    <span>Save as draft</span>
                </label>
            </div>
            <div class="form-row">
                <label asp-for="Input.Body"></label>
                <textarea asp-for="Input.Body" rows="18"></textarea>
                <span asp-validation-for="Input.Body"></span>
            </div>
            <div class="hero-actions">
                <button class="button-primary" type="submit">Save post</button>
                <a class="button-secondary" asp-page="/Admin/Blog/Index">Back to entries</a>
                @if (!Model.IsNew)
                {
                    <a class="button-secondary" href="/Blog/@Model.Input.Slug">View public post</a>
                }
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
