@page
@model LoginModel
@{
    ViewData["Title"] = "Admin Login";
}

<section class="page-section">
    <div class="container narrow">
        <p class="eyebrow">Admin</p>
        <h1>Sign in</h1>
        <div class="contact-panel contact-form-panel">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="form-alert error" role="alert" asp-validation-summary="ModelOnly"></div>
            }

            <form method="post" class="contact-form">
                <input type="hidden" asp-for="ReturnUrl" />
                <div class="form-row">
                    <label asp-for="Input.UserName"></label>
                    <input asp-for="Input.UserName" autocomplete="username" />
                    <span asp-validation-for="Input.UserName"></span>
                </div>
                <div class="form-row">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" type="password" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password"></span>
                </div>
                <button class="button-primary" type="submit">Sign in</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
