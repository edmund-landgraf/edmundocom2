@page
@{
    ViewData["Title"] = "Links";
}

<section class="page-section">
    <div class="container">
        <div class="section-intro">
            <p class="eyebrow">Links</p>
            <h1>Public shortcuts and authenticated destinations.</h1>
            <p>
                This can be a friendly public link space. If a destination needs authentication, the link can simply take
                visitors to that service and let it handle access.
            </p>
        </div>
        <div class="link-grid">
            <a href="https://unwhelm.net">
                <span>Business</span>
                <strong>unwhelm.net</strong>
                <em>Client-facing services and consulting information.</em>
            </a>
            <a href="https://photos.google.com">
                <span>Media</span>
                <strong>Shared albums</strong>
                <em>Public albums can open directly; private ones will ask for sign-in.</em>
            </a>
            <a href="https://drive.google.com">
                <span>Files</span>
                <strong>Shared documents</strong>
                <em>Documents, lists, and plans can live behind normal Google authentication.</em>
            </a>
            <a href="https://maps.google.com">
                <span>Travel</span>
                <strong>Maps and places</strong>
                <em>Trip maps, saved places, routes, and public location lists.</em>
            </a>
        </div>
    </div>
</section>
